run = "npm run start"
entrypoint = "app/page.tsx"
modules = ["nodejs-20"]
hidden = [".next", "node_modules"]

[nix]
channel = "stable-23_11"

[deployment]
run = ["sh", "-c", "npm run start"]
build = ["sh", "-c", "npm install && npm run build"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 3000
externalPort = 80
